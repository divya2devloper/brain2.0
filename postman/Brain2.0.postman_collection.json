    {
      "name": "WhatsApp",
      "item": [
        {
          "name": "Webhook Verify",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/whatsapp/webhook?hub.verify_token={{webhookVerifyToken}}&hub.challenge=12345",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "whatsapp",
                "webhook"
              ],
              "query": [
                {
                  "key": "hub.verify_token",
                  "value": "{{webhookVerifyToken}}"
                },
                {
                  "key": "hub.challenge",
                  "value": "12345"
                }
              ]
            }
          }
        },
